    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Elastic CLI",
            "type": "coreclr",
            "request": "launch",
            //"preLaunchTask": "build",
            "program": "${workspaceFolder}/src/Charon.Elastic.Cli/bin/Debug/net10.0/charon-elastic",
            "args": [
                "--path",
                "${cwd}/../../Services",
                "es"
            ],
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false
        }
    ]
}